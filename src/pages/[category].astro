---
import Layout from '../layouts/Layout.astro';
import GalleryGrid from '../components/GalleryGrid.jsx';
import { getCrmPortfolio } from '../lib/crm';
import {
	absoluteUrl,
	buildBreadcrumbJsonLd,
	buildImageGalleryJsonLd,
	categoryDescription,
	categorySeo,
	categoryTitle,
	coverAlt,
	imageAlt,
	sortPortfolioItems,
	STATIC_CATEGORY_ROUTES,
} from '../lib/seo';

const { category } = Astro.params;
const portfolio = await getCrmPortfolio();
const found = portfolio.find((cat) => cat.slug === category);

if (!found || STATIC_CATEGORY_ROUTES.has(found.slug)) {
	return Astro.redirect('/404');
}

const cat = {
	title: found.name,
	slug: found.slug,
	description: found.description,
	cover_image: found.cover_image,
};

const images = sortPortfolioItems(found.items).map((item, index) => ({
	src: item.image_url,
	title: item.title?.trim() ?? '',
	alt: imageAlt(item.title, cat.title, index),
	description: item.description?.trim() ?? '',
}));

const items = found.items;
const seo = categorySeo(cat.slug, cat.title);
const pageDescription = categoryDescription(cat.title, cat.slug, cat.description);
const visibleDescription = cat.description?.trim() || seo.description;
const pageTitle = categoryTitle(cat.title, cat.slug);
const pageUrl = absoluteUrl(`/${cat.slug}`);
const breadcrumbs = [
	{ name: 'Home', path: '/' },
	{ name: cat.title, path: `/${cat.slug}` },
];
---

<Layout
	title={pageTitle}
	description={pageDescription}
	image={cat.cover_image ?? undefined}
	imageAlt={coverAlt(cat.title)}
	jsonLd={[
		buildBreadcrumbJsonLd(breadcrumbs),
		buildImageGalleryJsonLd(
			{ name: cat.title, slug: cat.slug, description: cat.description },
			items,
			pageUrl,
		),
	]}
>
	<nav aria-label="Breadcrumb" class="mb-6 text-sm text-gray-500">
		<ol class="flex flex-wrap items-center justify-center gap-2 font-light tracking-wide">
			<li>
				<a href="/" class="hover:text-gray-900 transition-colors">Home</a>
			</li>
			<li aria-hidden="true">/</li>
			<li class="text-gray-800" aria-current="page">{cat.title}</li>
		</ol>
	</nav>

	<div class="py-6 text-center mb-8">
		<h1 class="text-4xl md:text-5xl font-heading uppercase tracking-widest">{cat.title}</h1>
		<p class="mt-3 text-sm uppercase tracking-[0.25em] text-gray-400">{seo.subtitle}</p>
		<p class="mt-4 max-w-2xl mx-auto text-gray-600 font-light leading-relaxed">{visibleDescription}</p>
		<p class="mt-2 text-xs text-gray-400">{items.length} works</p>
	</div>

	<GalleryGrid images={images} client:load />
</Layout>
