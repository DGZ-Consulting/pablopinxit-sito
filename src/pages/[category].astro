---
import Layout from '../layouts/Layout.astro';
import GalleryGrid from '../components/GalleryGrid.jsx';
import { getCrmPortfolio } from '../lib/crm';
import {
	absoluteUrl,
	buildBreadcrumbJsonLd,
	buildImageGalleryJsonLd,
	categoryDescription,
	categoryTitle,
	coverAlt,
	filterGalleryItems,
	imageAlt,
	sortPortfolioItems,
	STATIC_CATEGORY_ROUTES,
} from '../lib/seo';

const { category } = Astro.params;
const portfolio = await getCrmPortfolio();
const found = portfolio.find((cat) => cat.slug === category);

if (!found || STATIC_CATEGORY_ROUTES.has(found.slug)) {
	return Astro.redirect('/404');
}

const cat = {
	title: found.name,
	slug: found.slug,
	description: found.description,
	cover_image: found.cover_image,
};

const galleryItems = filterGalleryItems(
	sortPortfolioItems(found.items),
	cat.cover_image,
	cat.title,
);

const images = galleryItems.map((item, index) => ({
	src: item.image_url,
	title: item.title?.trim() ?? '',
	alt: imageAlt(item.title, cat.title, index),
	description: item.description?.trim() ?? '',
}));

const pageDescription = categoryDescription(cat.title, cat.slug, cat.description);
const pageTitle = categoryTitle(cat.title, cat.slug);
const pageUrl = absoluteUrl(`/${cat.slug}`);
const breadcrumbs = [
	{ name: 'Home', path: '/' },
	{ name: cat.title, path: `/${cat.slug}` },
];
---

<Layout
	title={pageTitle}
	description={pageDescription}
	image={cat.cover_image ?? undefined}
	imageAlt={coverAlt(cat.title)}
	jsonLd={[
		buildBreadcrumbJsonLd(breadcrumbs),
		buildImageGalleryJsonLd(
			{ name: cat.title, slug: cat.slug, description: cat.description },
			galleryItems,
			pageUrl,
		),
	]}
>
	<div class="py-6 text-center mb-8">
		<h1 class="text-4xl md:text-5xl font-heading uppercase tracking-widest">{cat.title}</h1>
	</div>

	<section aria-label={`${cat.title} gallery`}>
		<GalleryGrid images={images} categoryTitle={cat.title} client:load />

		<!-- SEO: full image list for crawlers -->
		<div class="sr-only" aria-hidden="true">
			{images.map((img) => (
				<figure>
					<img src={img.src} alt={img.alt} loading="lazy" />
					{img.title && <figcaption>{img.title}</figcaption>}
				</figure>
			))}
		</div>
	</section>
</Layout>

<style>
	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
</style>
