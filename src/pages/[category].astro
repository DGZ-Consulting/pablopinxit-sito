---
import Layout from '../layouts/Layout.astro';
import GalleryGrid from '../components/GalleryGrid.jsx';
import { getCrmPortfolio } from '../lib/crm';

export async function getStaticPaths() {
  const portfolio = await getCrmPortfolio();
  return portfolio.map((cat) => ({
    params: { category: cat.slug },
    props: {
      cat: { title: cat.name, slug: cat.slug },
      images: cat.items.map(item => ({
        src: item.image_url,
        title: item.title ?? '',
      })),
    },
  }));
}

const { cat, images } = Astro.props;
---

<Layout title={`${cat.title} | Pablo Pinxit`}>
    <div class="py-6 text-center mb-8">
        <h1 class="text-4xl md:text-5xl font-heading uppercase tracking-widest">{cat.title}</h1>
    </div>

    <GalleryGrid images={images} client:load />
</Layout>
