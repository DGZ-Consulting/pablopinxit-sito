---
import Layout from '../layouts/Layout.astro';
import { getCrmPortfolio } from '../lib/crm';

const portfolio = await getCrmPortfolio();
---

<Layout title="Pablo Pinxit | Visual Artist">
	<section class="max-w-[95%] mx-auto py-4">
		<div class="grid grid-cols-2 gap-4">
			{portfolio.map((cat) => (
				<a href={`/${cat.slug}`} class="group relative aspect-[20/19] overflow-hidden block">
					<div
						class="absolute inset-0 bg-cover bg-center transition-transform duration-700"
						style={`background-image: url('${cat.cover_image}');`}
					>
					</div>

					<div class="absolute inset-0 bg-white/0 group-hover:bg-white/85 transition-colors duration-500 ease-in-out"></div>

					<div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-100">
						<h2 class="text-gray-900 text-3xl md:text-5xl font-heading tracking-widest uppercase text-center px-4">
							{cat.name}
						</h2>
					</div>
				</a>
			))}

			<a href="/about" class="col-span-2 md:col-span-1 group relative h-40 md:h-80 overflow-hidden block bg-[#1a1a1a] hover:bg-[#800000] transition-colors duration-500 flex items-center justify-center">
				<h2 class="text-white text-4xl font-heading font-thin tracking-widest uppercase group-hover:text-white transition-colors">
					About
				</h2>
			</a>

			<a href="/contact" class="col-span-2 md:col-span-1 group relative h-40 md:h-80 overflow-hidden block bg-[#1a1a1a] hover:bg-[#800000] transition-colors duration-500 flex items-center justify-center">
				<h2 class="text-white text-4xl font-heading font-thin tracking-widest uppercase group-hover:text-white transition-colors">
					Contact
				</h2>
			</a>
		</div>
	</section>
</Layout>
