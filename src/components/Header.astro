---
import Navigation from './Navigation.jsx';

const { categories = [] } = Astro.props;
---

<header class="fixed top-0 left-0 w-full bg-white z-[300] transition-all duration-300">
    <div class="max-w-7xl mx-auto px-4 md:px-8 pt-4 pb-3 md:pt-5 md:pb-3 flex items-center justify-between">
        <a href="/" class="text-4xl md:text-5xl font-heading font-thin tracking-wider hover:opacity-70 transition-opacity z-[310] relative text-gray-800">
            Pablo Pinxit
        </a>

        <Navigation categories={categories} client:load />
    </div>
</header>
