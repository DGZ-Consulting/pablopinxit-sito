---
import Navigation from './Navigation.jsx';
---

<header class="fixed top-0 left-0 w-full bg-white z-50 transition-all duration-300">
    <div class="max-w-5xl mx-auto px-4 md:px-8 pt-8 pb-4 flex items-center justify-between">
        <!-- Logo -->
        <a href="/" class="text-4xl md:text-5xl font-heading font-thin tracking-wider hover:opacity-70 transition-opacity z-50 relative text-gray-800">
            Pablo Pinxit
        </a>

        <!-- Interactive Navigation (React Component) -->
        <Navigation client:load />
    </div>
</header>
