<footer class="py-12 bg-white relative">
    <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row items-center justify-center relative">
        
        <!-- Copyright Text -->
        <p class="text-[17px] text-[#111111] font-heading font-[800] tracking-widest text-center mb-[30px]">
            &copy; Pablo Pinxit Visual Artist | [ Italy ]
        </p>

        <!-- Scroll to Top Button (Absolute Right on Desktop, centered bottom on mobile) -->
        <button 
            onclick="window.scrollTo({top: 0, behavior: 'smooth'})"
            class="mt-4 md:mt-0 md:absolute md:right-8 w-10 h-10 bg-[#1a1a1a] text-white flex items-center justify-center hover:bg-black transition-colors cursor-pointer"
            aria-label="Scroll to top"
        >
            <span class="text-xl">&uarr;</span>
        </button>

    </div>
</footer>
